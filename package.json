{
  "name": "internal-crm-helpdesk",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:frontend": "vite --config frontend/app-extension-ui/vite.config.ts",
    "build:frontend": "vite build --config frontend/app-extension-ui/vite.config.ts",
    "preview:frontend": "vite preview --config frontend/app-extension-ui/vite.config.ts",
    "build": "tsc && vite build --config frontend/app-extension-ui/vite.config.ts",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p frontend/app-extension-ui/tsconfig.json",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "express": "^4.19.0",
    "drizzle-orm": "^0.45.0",
    "pipedrive": "^32.0.0",
    "@pipedrive/app-extensions-sdk": "^0.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "mysql2": "^3.9.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "drizzle-kit": "^0.31.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.2.0"
  }
}
